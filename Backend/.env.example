APP_NAME=FortiCorpAPI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://bgadmin.forticorp.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=FortiCorp
DB_USERNAME=postgres
DB_PASSWORD=secret
DB_SSLMODE=disable

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

CORS_ALLOWED_ORIGINS=https://crm.forticorp.com.br,https://forticorp.com.br,https://www.forticorp.com.br

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

EVOLUTION_API_URL=evo.forticorp.com.br
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=FortiCorp
EVOLUTION_WEBHOOK_URL=
EVOLUTION_REALTIME_MODE=polling
EVOLUTION_POLLING_INTERVAL=10
EVOLUTION_TIMEOUT=20
EVOLUTION_CONNECT_TIMEOUT=20
WHATSAPP_POST_MAX_SIZE=64M
WHATSAPP_UPLOAD_MAX_FILESIZE=64M
WHATSAPP_MEMORY_LIMIT=256M

# Seed de configuracoes gerais/integracoes (database/seeders/GeneralSettingsSeeder.php)
SETTINGS_COMPANY_NAME=FortiCorp
SETTINGS_CONTACT_EMAIL=contato@forticorp.com.br
SETTINGS_CONTACT_PHONE=
SETTINGS_CONTACT_WHATSAPP=
SETTINGS_CONTACT_WHATSAPP_URL=
SETTINGS_CONTACT_ADDRESS=

META_PIXEL_ENABLED=false
META_PIXEL_ID=
META_PIXEL_AUTO_ADVANCED_MATCHING=false
META_PIXEL_MATCH_CITY_STATE_ZIP=false
META_PIXEL_MATCH_COUNTRY=false
META_PIXEL_MATCH_BIRTH_DATE=false
META_PIXEL_MATCH_EMAIL=true
META_PIXEL_MATCH_EXTERNAL_ID=false
META_PIXEL_MATCH_GENDER=false
META_PIXEL_MATCH_FIRST_LAST_NAME=true
META_PIXEL_MATCH_PHONE=true

META_CAPI_ENABLED=false
META_CAPI_ACCESS_TOKEN=
META_CAPI_API_VERSION=v22.0
META_CAPI_TEST_EVENT_CODE=

# Regras de score e mapeamento de origem (JSON completo opcional)
# SETTINGS_SCORE_RULES_JSON={"utm_source_bonus":10,"page_view_weight":2}
# SETTINGS_SOURCE_MAPPINGS_JSON={"rules":[{"contains":"whatsapp","label":"Botao WhatsApp","priority":80,"is_active":true}]}
SETTINGS_SCORE_RULES_JSON=
SETTINGS_SOURCE_MAPPINGS_JSON=

# Prazos internos do onboarding (JSON opcional)
# SETTINGS_ONBOARDING_DEADLINES_JSON={"urgente":3,"mes":15,"30-60":35,"sem-pressa":90}
SETTINGS_ONBOARDING_DEADLINES_JSON=

# Distribuicao de leads
SETTINGS_DISTRIBUTION_ENABLED=true
SETTINGS_DISTRIBUTION_FALLBACK_RULE=unassigned
SETTINGS_DISTRIBUTION_FALLBACK_USER_ID=
SETTINGS_DISTRIBUTION_CURRENT_INDEX=0

# Precificacao (JSON opcional para sobrescrever defaults)
# SETTINGS_PRICING_PROJECT_SETTINGS_JSON=[{"project_type":"site","max_discount_percent":40,"requires_admin_validation":false}]
# SETTINGS_PRICING_RULE_ITEMS_JSON=[{"project_type":"site","rule_key":"objective_leads","label":"Site objetivo: Gerar leads","amount":350,"sort_order":2,"is_active":true}]
SETTINGS_PRICING_PROJECT_SETTINGS_JSON=
SETTINGS_PRICING_RULE_ITEMS_JSON=

# WhatsApp (persistido no banco pelo seeder)
WHATSAPP_SIGN_MESSAGES=false
